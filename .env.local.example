# Published CSV URL for the "Approved Events" tab in your Google Sheet
# How to get this: Sheet → File → Share → Publish to web → select tab → CSV → Copy link
GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/export?format=csv&gid=GID

# Optional: separate CSV URL for raw Google Form submissions tab
RAW_SUBMISSIONS_CSV_URL=

# The Google Form URL (viewform link) — used as a fallback / "prefer the form?" link
NEXT_PUBLIC_GOOGLE_FORM_URL=https://docs.google.com/forms/d/FORM_ID/viewform

# Apps Script web app /exec URL — powers the native submit form (URL/notes/name + photo).
# Deploy the script as a Web App (Execute as: Me, Access: Anyone) and paste the URL here.
NEXT_PUBLIC_SUBMIT_ENDPOINT=https://script.google.com/macros/s/DEPLOYMENT_ID/exec
